{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "lib": ["ES2022"],
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "outDir": "out",
    "rootDir": "src",
    "types": ["node"],
    "skipLibCheck": true,
    "declaration": false,
    "sourceMap": false
  },
  "include": ["src/core/**/*", "src/api/**/*", "src/cli/**/*"]
}
